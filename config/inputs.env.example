# ------------------------------
# vCenter connection
# ------------------------------
VCENTER_SERVER="10.10.10.9"
VCENTER_USERNAME="administrator@vsphere.local"
VCENTER_PASSWORD="REPLACE_ME"
VCENTER_DATACENTER="HOMELAB"
VCENTER_CLUSTER="Primary"
VCENTER_DATASTORE="NVME_2TB_970_SAMSUNG_EVO_M.2"
VCENTER_NETWORK="VM Network"

# ------------------------------
# Build and publish targets
# ------------------------------
VCENTER_BUILD_FOLDER="Builds/Linux/Ubuntu"
VCENTER_TEST_FOLDER="Testing/Linux/Ubuntu"
VCENTER_DEPLOY_FOLDER="Production/Linux/Ubuntu"
CONTENT_LIBRARY_NAME="UBUNTU"
CONTENT_LIBRARY_ITEM_NAME="ubuntu-24.04-minimal"
CONTENT_LIBRARY_DESCRIPTION="Ubuntu 24.04 LTS minimal template"
CONTENT_LIBRARY_OVF=true
CONTENT_LIBRARY_DESTROY=false
CONVERT_TO_TEMPLATE=true

# ------------------------------
# Build image and baked-in artifacts
# ------------------------------
UBUNTU_ISO_URL="https://releases.ubuntu.com/24.04/ubuntu-24.04.1-live-server-amd64.iso"
UBUNTU_ISO_CHECKSUM="sha256:e240e9b0bd030387183e8406129188e9989300305156a00c6d70a441e8c1471d"
PACKER_VM_NAME="ubuntu-2404-minimal-base"
PACKER_FIRMWARE="bios"
PACKER_SSH_USERNAME="ansible"
PACKER_SSH_PASSWORD="REPLACE_ME"
TEMPLATE_CPU_COUNT="2"
TEMPLATE_MEMORY_MB="2048"
TEMPLATE_DISK_SIZE_MB="20480"

# ------------------------------
# Automated deploy defaults
# ------------------------------
DEPLOY_VM_NAME="ubuntu-node-01"
DEPLOY_CPU_COUNT="2"
DEPLOY_MEMORY_MB="4096"

# ------------------------------
# Deploy-time node identity
# ------------------------------
NODE_HOSTNAME="ubuntu-01"
NODE_FQDN="ubuntu-01.mgmt.example.com"

# ------------------------------
# SSH and admin access
# ------------------------------
SSH_ADMIN_USERNAME="ansible"
SSH_ADMIN_GROUP="sudo"
SSH_ADMIN_SSH_PUBKEY="REPLACE_WITH_SSH_PUBLIC_KEY"
SSH_ADMIN_CIDRS="10.10.10.0/24"

# ------------------------------
# DNS / NTP
# ------------------------------
DNS_SERVERS="1.1.1.1,8.8.8.8"
DNS_SEARCH_DOMAINS="example.com"
NTP_SERVERS="0.ubuntu.pool.ntp.org,1.ubuntu.pool.ntp.org"
