# ==========================================================
# 1. GLOBAL VCENTER CONNECTION
# ==========================================================
VCENTER_SERVER="10.10.10.9"
VCENTER_USERNAME="administrator@vsphere.local"
VCENTER_PASSWORD="REPLACE_ME"

# ==========================================================
# 2. BUILD INFRASTRUCTURE (CONTENT LIBRARY)
# ==========================================================
CONTENT_LIBRARY_NAME="UBUNTU"
CONTENT_LIBRARY_ITEM_NAME="ubuntu-26.04-minimal"
CONTENT_LIBRARY_DESCRIPTION="Ubuntu 26.04 LTS minimal template"
CONTENT_LIBRARY_OVF=true
CONVERT_TO_TEMPLATE=true

# ==========================================================
# 3. BUILD SPECIFICATIONS (OS & BASELINE)
# ==========================================================
UBUNTU_ISO_URL="https://releases.ubuntu.com/26.04/ubuntu-26.04-live-server-amd64.iso"
UBUNTU_ISO_CHECKSUM="sha256:dec49008a71f6098d0bcfc822021f4d042d5f2db279e4d75bdd981304f1ca5d9"
PACKER_VM_NAME="ubuntu-2604-minimal-base"
PACKER_FIRMWARE="bios"
PACKER_SSH_USERNAME="ansible"
PACKER_SSH_PASSWORD="REPLACE_ME"

TEMPLATE_CPU_COUNT="2"
TEMPLATE_MEMORY_MB="2048"
TEMPLATE_DISK_SIZE_MB="20480"

# ==========================================================
# 4. DEPLOYMENT INFRASTRUCTURE
# ==========================================================
VCENTER_DATACENTER="HOMELAB"
VCENTER_CLUSTER="Primary"
VCENTER_DATASTORE="NVME_2TB_970_SAMSUNG_EVO_M.2"
VCENTER_NETWORK="VM Network"
DEPLOY_ESXI_HOST="" # Optional: Specify a specific host (e.g., 10.10.10.10)

# Folder Hierarchy
VCENTER_TEMPLATE_FOLDER="Builds/Linux/Ubuntu/Templates"
VCENTER_BUILD_TEST_FOLDER="Builds/Linux/Ubuntu/Test"
VCENTER_DEPLOY_PROD_FOLDER="Deploy/Linux/Ubuntu/Prod"
VCENTER_DEPLOY_TEST_FOLDER="Deploy/Linux/Ubuntu/Test"

# ==========================================================
# 5. DEPLOYMENT CUSTOMIZATIONS (DEFAULT VM IDENTITY)
# ==========================================================
DEPLOY_VM_NAME="ubuntu-node-01"
DEPLOY_CPU_COUNT="2"
DEPLOY_MEMORY_MB="4096"

NODE_HOSTNAME="ubuntu-01"
NODE_FQDN="ubuntu-01.mgmt.example.com"

# Admin Access
SSH_ADMIN_USERNAME="ansible"
SSH_ADMIN_GROUP="sudo"
SSH_ADMIN_SSH_PUBKEY="ssh-rsa AAAAB3Nza..."
SSH_PRIVATE_KEY_PATH="~/.ssh/id_rsa"
SSH_ADMIN_CIDRS="10.10.10.0/24"

# NTP
NTP_SERVERS="0.ubuntu.pool.ntp.org,1.ubuntu.pool.ntp.org"
